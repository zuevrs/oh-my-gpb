{
  "schemaVersion": 1,
  "contractId": "akita-promote-state",
  "localStateBasePath": ".oma/state/local/promote",
  "installedTemplateBasePath": ".oma/templates/promote",
  "writePrerequisites": {
    "contractPath": ".oma/templates/write/state-contract.json",
    "sharedStateBasePath": ".oma/state/shared/write",
    "requiredStatePaths": [
      ".oma/state/shared/write/write-report.json"
    ],
    "promoterMustReadFromDisk": true,
    "description": "akita-promote must consume the persisted write report above and stop when it is missing instead of guessing which generated artifacts are eligible for promotion."
  },
  "requiredMachineState": [
    {
      "id": "promote-report",
      "path": ".oma/state/local/promote/promote-report.json",
      "format": "json",
      "required": true,
      "requiredTopLevelFields": [
        "verdict",
        "requestedPromotions",
        "promotedArtifacts",
        "findings"
      ],
      "description": "Canonical local promotion trace. It must record the explicit promotion request, each copied live destination, and every blocker or refusal in one durable JSON file."
    }
  ],
  "promotionActions": [
    {
      "id": "promote-artifact",
      "command": "promote <artifact-id> to <repo-relative-path>",
      "kind": "promote",
      "copiesArtifact": true,
      "description": "Copy one generated artifact into an explicit live repo-relative destination."
    },
    {
      "id": "accept-artifact",
      "command": "accept <artifact-id> as <repo-relative-path>",
      "kind": "accept",
      "copiesArtifact": true,
      "description": "Accept one generated artifact and copy it into an explicit live repo-relative destination."
    }
  ],
  "promotionPolicy": {
    "sourceWriteReportPath": ".oma/state/shared/write/write-report.json",
    "sourceBasePath": ".oma/generated",
    "allowedSourceRoots": [
      ".oma/generated/features",
      ".oma/generated/payloads",
      ".oma/generated/fixtures"
    ],
    "explicitDestinationRequired": true,
    "destinationMustBeRepoRelative": true,
    "forbiddenDestinationRoots": [
      ".oma/",
      ".opencode/"
    ],
    "allowOverwriteExistingFiles": false,
    "copyInsteadOfMove": true,
    "keepGeneratedSourceAfterPromote": true,
    "requiredPromotedArtifactFields": [
      "artifactId",
      "artifactKind",
      "sourcePath",
      "destinationPath",
      "sourceSha256"
    ],
    "description": "akita-promote must treat write-report as the source-of-truth artifact bundle, require explicit human-chosen live destinations, copy instead of move, and refuse overwrites or pack-managed destinations."
  },
  "stopConditions": [
    {
      "id": "missing-write-report",
      "classification": "blocked",
      "reportIn": "promote-report",
      "description": "The write report is missing, so promotion cannot know which generated artifact bundle is eligible."
    },
    {
      "id": "unknown-artifact-id",
      "classification": "needs-review",
      "reportIn": "promote-report",
      "description": "The request names an artifact id that is not present in the current write report."
    },
    {
      "id": "missing-explicit-destination",
      "classification": "needs-review",
      "reportIn": "promote-report",
      "description": "Promotion requires an explicit repo-relative destination for each accepted artifact."
    },
    {
      "id": "missing-generated-source",
      "classification": "blocked",
      "reportIn": "promote-report",
      "description": "The generated source file recorded in write-report is missing on disk."
    },
    {
      "id": "source-outside-generated-namespace",
      "classification": "blocked",
      "reportIn": "promote-report",
      "description": "The emitted source path falls outside the contract-defined generated namespace."
    },
    {
      "id": "invalid-destination-path",
      "classification": "blocked",
      "reportIn": "promote-report",
      "description": "The requested destination is not a safe repo-relative path."
    },
    {
      "id": "destination-under-pack-managed-root",
      "classification": "blocked",
      "reportIn": "promote-report",
      "description": "Promotion must not publish into `.oma/` or `.opencode/`."
    },
    {
      "id": "destination-conflict",
      "classification": "blocked",
      "reportIn": "promote-report",
      "description": "The destination already exists, so promotion must stop instead of overwriting it."
    }
  ],
  "summaryState": {
    "path": ".oma/state/local/promote/promote-summary.md",
    "templatePath": ".oma/templates/promote/promote-summary.md",
    "format": "markdown",
    "required": false,
    "canonical": false,
    "mustBeDerivedFrom": [
      "promote-report"
    ],
    "description": "Human-readable promotion summary only. Canonical machine state stays in the JSON file above."
  },
  "redaction": {
    "policyPath": ".oma/runtime/shared/data-handling-policy.json",
    "redactionRequired": true,
    "markdownIsSummaryOnly": true,
    "forbiddenSharedData": [
      "secrets",
      "tokens",
      "credentials",
      "raw auth headers",
      "machine-local values"
    ],
    "allowedSharedData": [
      "artifact ids",
      "artifact kinds",
      "repo-relative source paths",
      "repo-relative destination paths",
      "promotion findings"
    ]
  }
}
