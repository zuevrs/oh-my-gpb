{
  "schemaVersion": 1,
  "contractId": "akita-scan-state",
  "sharedStateBasePath": ".oma/state/shared/scan",
  "installedTemplateBasePath": ".oma/templates/scan",
  "requiredMachineState": [
    {
      "id": "contracts",
      "path": ".oma/state/shared/scan/contracts.json",
      "format": "json",
      "required": true,
      "description": "Discovered contract surfaces for the target repo, including OpenAPI inputs when present and code-first contract notes when OpenAPI is absent."
    },
    {
      "id": "target-candidates",
      "path": ".oma/state/shared/scan/target-candidates.json",
      "format": "json",
      "required": true,
      "description": "High-value target areas, endpoints, or entry points that later planning can choose from."
    },
    {
      "id": "prior-art",
      "path": ".oma/state/shared/scan/prior-art.json",
      "format": "json",
      "required": true,
      "description": "Repo-local prior art that may inform layout or style without widening capability truth."
    },
    {
      "id": "service-runtime-profile",
      "path": ".oma/state/shared/scan/service-runtime-profile.json",
      "format": "json",
      "required": true,
      "description": "Runtime characteristics, framework facts, and execution constraints relevant to flow design."
    },
    {
      "id": "flow-candidates",
      "path": ".oma/state/shared/scan/flow-candidates.json",
      "format": "json",
      "required": true,
      "description": "Candidate integration flows grounded in repo facts and manifest-listed capability truth."
    },
    {
      "id": "assertion-opportunities",
      "path": ".oma/state/shared/scan/assertion-opportunities.json",
      "format": "json",
      "required": true,
      "description": "Assertion surfaces and observable checkpoints that later slices can reuse for plan and validation work."
    }
  ],
  "summaryState": {
    "path": ".oma/state/shared/scan/scan-summary.md",
    "templatePath": ".oma/templates/scan/scan-summary.md",
    "format": "markdown",
    "required": false,
    "canonical": false,
    "mustBeDerivedFrom": [
      "contracts",
      "target-candidates",
      "prior-art",
      "service-runtime-profile",
      "flow-candidates",
      "assertion-opportunities"
    ],
    "description": "Human-readable summary only. Canonical machine state stays in the JSON files above."
  },
  "redaction": {
    "policyPath": ".oma/runtime/shared/data-handling-policy.json",
    "redactionRequired": true,
    "markdownIsSummaryOnly": true,
    "forbiddenSharedData": [
      "secrets",
      "tokens",
      "credentials",
      "raw auth headers",
      "machine-local values"
    ],
    "allowedSharedData": [
      "repo structure",
      "route hints",
      "prior-art paths",
      "capability evidence"
    ]
  }
}
